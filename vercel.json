{
  "version": 2,
  "buildCommand": null,
  "outputDirectory": "implementation/frontend",
  "rewrites": [
    {
      "source": "/tools",
      "destination": "/tools.html"
    },
    {
      "source": "/about",
      "destination": "/about.html"
    },
    {
      "source": "/docs",
      "destination": "/docs.html"
    },
    {
      "source": "/compliance",
      "destination": "/compliance.html"
    },
    {
      "source": "/results",
      "destination": "/results.html"
    },
    {
      "source": "/quick-assessment",
      "destination": "/quick-assessment.html"
    },
    {
      "source": "/comprehensive-assessment",
      "destination": "/comprehensive-assessment.html"
    },
    {
      "source": "/org-profile",
      "destination": "/org-profile.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" }
      ]
    },
    {
      "source": "/(.*\\.js)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
